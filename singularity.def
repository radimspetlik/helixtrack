Bootstrap:docker
From:ubuntu:22.04

%environment
    export LD_LIBRARY_PATH=/usr/local/lib:${LD_LIBRARY_PATH}
    export HDF5_PLUGIN_PATH=/usr/local/hdf5/lib/plugin:${HDF5_PLUGIN_PATH}

%runscript
    . /etc/profile

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get -y update
    apt-get install -y \
        apt-utils \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        ffmpeg \
        gdb \
        git \
        hdf5-tools \
        htop \
        libboost-all-dev \
        libcanberra-gtk-module \
        libceres-dev \
        libeigen3-dev \
        libglew-dev \
        libglfw3-dev \
        libhdf5-dev \
        libogre-1.12-dev \
        libopencv-dev \
        libprotobuf-dev \
        libtiff5-dev \
        libusb-1.0-0-dev \
        libyaml-cpp-dev \
        mesa-utils \
        pkg-config \
        protobuf-compiler \
        python3-dev \
        python3-opencv \
        python3-pip \
        software-properties-common \
        unzip \
        valgrind \
        wget \
        zip

    ln -fs /usr/share/zoneinfo/Europe/Prague /etc/localtime
    apt-get install -y tzdata
    dpkg-reconfigure --frontend noninteractive tzdata

    # ---- pybind11 installation
    rm -rf /tmp/pybind11-2.11.0 /tmp/pybind11-2.11.0.zip
    wget -q -O /tmp/pybind11-2.11.0.zip https://github.com/pybind/pybind11/archive/v2.11.0.zip
    unzip -q /tmp/pybind11-2.11.0.zip -d /tmp
    cmake -S /tmp/pybind11-2.11.0 -B /tmp/pybind11-2.11.0/build \
        -DPYBIND11_TEST=OFF \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build /tmp/pybind11-2.11.0/build --parallel "$(nproc)"
    cmake --install /tmp/pybind11-2.11.0/build

    # ---- OPENEB compilation
    rm -rf /tmp/openeb
    git clone --depth 1 --branch 5.2.0 https://github.com/prophesee-ai/openeb.git /tmp/openeb
    cmake -S /tmp/openeb -B /tmp/openeb/build \
        -DBUILD_TESTING=OFF \
        -DBUILD_PYTHON_BINDINGS=OFF \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build /tmp/openeb/build --parallel "$(nproc)"
    cmake --install /tmp/openeb/build
    ldconfig

    # Create some common mountpoints for systems without overlayfs
    mkdir -p /scratch
    mkdir -p /apps

    . /etc/profile
